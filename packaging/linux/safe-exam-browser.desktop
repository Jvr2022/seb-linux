[Desktop Entry]
Version=1.0
Type=Application
Name=Safe Exam Browser
GenericName=Secure exam browser for Linux
Comment=Launch secure exams, open .seb files, and handle seb:// links
Exec=safe-exam-browser %u
Icon=safe-exam-browser
Terminal=false
Categories=Education;Network;WebBrowser;Qt;
MimeType=application/x-seb;x-scheme-handler/seb;x-scheme-handler/sebs;
StartupNotify=true
StartupWMClass=Safe Exam Browser
